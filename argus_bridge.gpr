project Argus_Bridge is
   -- This tells the compiler where your source code files are
   for Source_Dirs use ("src", "bridge");
   
   for Object_Dir use "obj";
   for Library_Name use "argus_bridge";
   for Library_Dir use "lib";

   package Compiler is
      for Default_Switches ("Ada") use ("-O3", "-gnatp");
   end Compiler;
end Argus_Bridge;
